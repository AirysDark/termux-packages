#!/usr/bin/env bash
# ldd-linux.sh - List shared library dependencies for binaries (Linux-native)
# Usage: ./ldd-linux.sh <binary> [<binary2> ...]

set -euo pipefail

if [[ $# -lt 1 ]]; then
    echo "Usage: $0 <binary> [<binary2> ...]"
    exit 1
fi

for bin in "$@"; do
    if [[ ! -f "$bin" ]]; then
        echo "File not found: $bin" >&2
        continue
    fi
    echo "Dependencies for: $bin"
    objdump -x "$bin" 2>/dev/null | grep NEEDED | awk '{print $2}' | sort
    echo
done