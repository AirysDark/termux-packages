#!/usr/bin/env bash
##
## validation.sh - Batch build Golang/Zig packages with splitting & CI summary
##

set -euo pipefail

cd "$(realpath "$(dirname "$0")/../..")" || { echo "ERROR: failed to cd to repo root"; exit 1; }

# Read packages directories from repo.json
readarray -t TERMUX_PACKAGE_DIRECTORIES < <(jq --raw-output 'del(.pkg_format) | keys | .[]' repo.json)

usage() {
	echo "USAGE: $0 ARCH PACKAGES [list|batch_number]"
	echo
	echo "OPTIONS:"
	echo "  ARCH     - aarch64, arm, i686, x86_64"
	echo "  PACKAGES - golang, zig"
	echo
	echo "EXAMPLES:"
	echo "  $0 aarch64 golang         Build all aarch64 golang-based packages"
	echo "  $0 aarch64 golang list    Split aarch64 golang-based package list"
	echo "  $0 aarch64 golang 2       Build 2nd batch of said list"
	exit 1
}

# Validate architecture
case "${1:-}" in
	aarch64|arm|i686|x86_64)
		ARCH="${1}"
		;;
	*)
		echo "ERROR: Invalid architecture: $1" 1>&2
		usage
		;;
esac

# Prepare packages list based on second argument
STRATEGY=(50 50)
EXCLUDE_BIG_PACKAGES=false
BIG_PACKAGES_IN_SEPARATE_BATCH=false

case "${2:-}" in
	golang)
		readarray -t PACKAGES < <(
			grep -rl termux_setup_golang --include=build.sh --exclude-dir=golang "${TERMUX_PACKAGE_DIRECTORIES[@]}" \
			| cut -d/ -f1,2 | sort -u | cut -d/ -f2 || :
		)
		STRATEGY=(100)
		EXCLUDE_BIG_PACKAGES=true
		BIG_PACKAGES_IN_SEPARATE_BATCH=true
		;;
	zig)
		readarray -t PACKAGES < <(
			grep -rl termux_setup_zig --include=build.sh --exclude-dir=zig "${TERMUX_PACKAGE_DIRECTORIES[@]}" \
			| cut -d/ -f1,2 | sort -u | cut -d/ -f2 || :
		)
		STRATEGY=(100)
		;;
	*)
		echo "ERROR: Invalid packages: $2" 1>&2
		usage
		;;
esac

# Validate strategy sums to 100%
SUM_PERCENT=0
for PERCENT in "${STRATEGY[@]}"; do
	SUM_PERCENT=$((SUM_PERCENT + PERCENT))
done
[[ "$SUM_PERCENT" -eq 100 ]] || { echo "ERROR: STRATEGY does not sum to 100"; exit 1; }

# ----------------------------
# Split packages into batches
# ----------------------------
split_build_job() {
	local PACKAGE_RATIO=()
	local CUM_PACKAGE_RATIO=()
	local PREV_RATIO=0
	local BATCH BATCHES=${#STRATEGY[@]}
	for BATCH in $(seq 0 $((BATCHES-1))); do
		PACKAGE_RATIO[BATCH]=$((STRATEGY[BATCH] * ${#PACKAGES[@]} / 100))
		CUM_PACKAGE_RATIO[BATCH]=$((PACKAGE_RATIO[BATCH] + PREV_RATIO))
		PREV_RATIO=${CUM_PACKAGE_RATIO[BATCH]}
	done

	# Handle remainder
	local REMAINDER=$((${#PACKAGES[@]} - CUM_PACKAGE_RATIO[-1]))
	PACKAGE_RATIO[-1]=$((PACKAGE_RATIO[-1]+REMAINDER))
	CUM_PACKAGE_RATIO[-1]=${#PACKAGES[@]}

	# Identify big packages
	unset BIG_PACKAGES
	BIG_PACKAGES=()
	local PACKAGE
	for PACKAGE in "${PACKAGES[@]}"; do
		if grep -Fxq "$PACKAGE" scripts/big-pkgs.list; then
			BIG_PACKAGES+=("$PACKAGE")
		fi
	done

	# Allocate packages per batch
	local PACKAGES1=() BATCH_NO=0 OLD_MIDPOINT=0 PACKAGE_NO
	for MIDPOINT in "${CUM_PACKAGE_RATIO[@]}"; do
		PACKAGE_NO=0
		for PACKAGE in "${PACKAGES[@]}"; do
			PACKAGE_NO=$((PACKAGE_NO+1))
			if [[ "$EXCLUDE_BIG_PACKAGES" == "true" ]] && [[ " ${BIG_PACKAGES[*]} " == *" $PACKAGE "* ]]; then
				continue
			fi
			if (( PACKAGE_NO <= OLD_MIDPOINT )); then continue; fi
			if (( PACKAGE_NO <= MIDPOINT )); then
				PACKAGES1+=("${BATCH_NO}:${PACKAGE}")
			else
				break
			fi
		done
		OLD_MIDPOINT=${MIDPOINT}
		BATCH_NO=$((BATCH_NO+1))
	done

	# Print batches
	local BATCH=0
	for PACKAGE in "${PACKAGES1[@]}"; do
		if [[ "$BATCH" != "${PACKAGE%:*}" ]]; then
			printf "\n"
			BATCH=$((BATCH+1))
			PACKAGE_NO=0
		fi
		if (( PACKAGE_NO == 0 )); then
			printf "%s" "${PACKAGE#*:}"
		else
			printf " %s" "${PACKAGE#*:}"
		fi
		PACKAGE_NO=$((PACKAGE_NO+1))
	done

	# Print big packages separately
	if [[ "$BIG_PACKAGES_IN_SEPARATE_BATCH" == "true" ]]; then
		printf "\n%s" "$(echo "${BIG_PACKAGES[@]}" | tr "\n" " " | sed 's/ $//')"
	fi
	printf "\n\nNumber of packages: %d\n" "${#PACKAGES[@]}"
	printf "Number of big packages: %d\n" "${#BIG_PACKAGES[@]}"
	printf "Batches (expected): %d\n" "${#STRATEGY[@]}"
}

# ----------------------------
# Parse third argument
# ----------------------------
if [[ "${3:-}" == "list" ]]; then
	split_build_job
	exit
elif [[ "${3:-}" =~ ^[0-9]+$ ]]; then
	readarray -t SPLIT_PACKAGES < <(split_build_job 2>/dev/null | head -n "$3" | tail -n1 | tr " " "\n")
	PACKAGES=("${SPLIT_PACKAGES[@]}")
elif [[ -n "${3:-}" ]]; then
	echo "ERROR: Invalid args: $*" 1>&2
	usage
fi

# ----------------------------
# Build packages
# ----------------------------
ms_to_human_readable() {
	echo "$(($1/3600000))h $(($1%3600000/60000))m $(($1%60000/1000))s $(($1%1000))ms" \
		| sed 's/0h //;s/0m //;s/0s //'
}

maybe_cleanup() {
	local PACKAGE="$1" CLEANUP_THRESHOLD=10
	[[ -z "$CI" ]] && return
	if grep -Fxq "$PACKAGE" scripts/big-pkgs.list || \
	   df "$HOME" | awk -v t="$CLEANUP_THRESHOLD" 'NR==2 {exit ($4/1024^2 < t ? 0 : 1)}'; then
		echo "INFO: Cleaning up before building ${PACKAGE}"
		./scripts/run-docker.sh ./clean.sh
		rm -rf ./output/*
	fi
}

echo "INFO: Rebuild list: ${PACKAGES[*]}" | tee "${GITHUB_STEP_SUMMARY:-/dev/null}"

declare -A failed=()
start_building_arch="$(date +%10s%3N)"
for package in "${PACKAGES[@]}"; do
	output=$(
		start="$(date +%10s%3N)"
		exec > >(tee /dev/fd/2) 2>&1
		echo "INFO: Building ${package} for ${ARCH}"
		maybe_cleanup "$package"
		./scripts/run-docker.sh ./build-package.sh -I -f -a "$ARCH" "$package"
		status="${PIPESTATUS[0]}"
		echo
		echo "INFO: Building ${package} for ${ARCH} took $(ms_to_human_readable $(( $(date +%10s%3N) - start )))"
		exit "$status"
	) || failed["${package} ${ARCH}"]="$output"
done

echo "INFO: Completed all packages for ${ARCH} in $(ms_to_human_readable $(( $(date +%10s%3N) - start_building_arch )))" | tee -a "${GITHUB_STEP_SUMMARY:-/dev/null}"

# ----------------------------
# Report failures
# ----------------------------
if (( ${#failed[@]} > 0 )); then
	{
		echo "### The packages below failed to build for ${ARCH}."
		for entry in "${!failed[@]}"; do
			echo "<details><summary><code>${entry% *}</code></summary><p>"
			echo ""
			echo "${failed["$entry"]}"
			echo ""
			echo "</p></details>"
		done
	} >> "${GITHUB_STEP_SUMMARY:-/dev/null}"
	exit 1
fi