#!/usr/bin/env python3
"""
revbump-linux.py - Increment TERMUX_PKG_REVISION for packages in packages-linux repo.

Maintainer: @T-Dynamos
"""

import os
import json
import sys

filename = os.path.basename(sys.argv[0])

USAGE = f"""
Usage:

{filename} <package> ...

Bump TERMUX_PKG_REVISION of the specified package(s).

{filename} --dependencies <package>

Bump TERMUX_PKG_REVISION of all packages that depend on <package>
via TERMUX_PKG_DEPENDS or TERMUX_PKG_BUILD_DEPENDS.
"""

# Determine repo.json path relative to this script
SCRIPT_DIR = os.path.dirname(os.path.realpath(sys.argv[0]))
REPO_JSON = os.path.join(SCRIPT_DIR, "..", "..", "repo.json")

# Load folders
with open(REPO_JSON) as f:
    repo_data = json.load(f)

FOLDERS = [folder for folder in repo_data.keys() if folder != "pkg_format"]


def is_dep(dep: str, line: str) -> bool:
    """Check if dep is present in a TERMUX_PKG_DEPENDS or BUILD_DEPENDS line."""
    deps_raw = line.split("=", 1)[1].strip()
    if deps_raw.startswith(("'", '"')):
        deps = [d.strip() for d in deps_raw[1:-1].split(",")]
    else:
        deps = [deps_raw]
    return dep in deps


def get_build_dependent_files(folders: list, dep: str) -> list:
    """Return all build.sh files depending on `dep`."""
    build_files = set()
    for d in folders:
        for pkg in os.listdir(d):
            pkg_path = os.path.join(d, pkg)
            build_sh = os.path.join(pkg_path, "build.sh")
            if os.path.isfile(build_sh):
                with open(build_sh) as f:
                    for line in f:
                        if line.startswith(("TERMUX_PKG_DEPENDS", "TERMUX_PKG_BUILD_DEPENDS")):
                            if is_dep(dep, line):
                                build_files.add(build_sh)

                # Check subpackages
                for subpkg_file in os.listdir(pkg_path):
                    if subpkg_file.endswith(".subpackage.sh"):
                        subpkg_path = os.path.join(pkg_path, subpkg_file)
                        with open(subpkg_path) as f:
                            for line in f:
                                if line.startswith("TERMUX_SUBPKG_DEPENDS") and is_dep(dep, line):
                                    build_files.add(build_sh)
    return list(build_files)


def bump_revision(file: str) -> None:
    """Increment TERMUX_PKG_REVISION or add it if missing."""
    with open(file) as f:
        lines = f.read().splitlines()

    revision = 0
    for idx, line in enumerate(lines):
        if line.startswith("TERMUX_PKG_REVISION"):
            rev_str = line.split("=", 1)[-1].strip().strip('"')
            revision = int(rev_str) + 1
            lines[idx] = f"TERMUX_PKG_REVISION={revision}"
            break

    if revision == 0:
        # Insert TERMUX_PKG_REVISION=1 after TERMUX_PKG_VERSION line
        insert_idx = next(
            (i for i, l in enumerate(lines) if l.startswith("TERMUX_PKG_VERSION")), len(lines) - 1
        )
        lines.insert(insert_idx + 1, "TERMUX_PKG_REVISION=1")
        revision = 1

    with open(file, "w") as f:
        f.write("\n".join(lines) + "\n")

    print(f"{revision - 1} -> {revision} {file}")


def locate_dir(package: str) -> str:
    """Locate package directory containing build.sh."""
    package_name = os.path.basename(package.rstrip("/"))
    for repo in FOLDERS:
        pkg_path = os.path.join(repo, package_name, "build.sh")
        if os.path.isfile(pkg_path):
            return pkg_path
    sys.exit(f"ERROR: Package '{package_name}' not found!")


def parse_args() -> None:
    if len(sys.argv) == 1 or sys.argv[1] in ("--help", "-h"):
        print(USAGE)
        sys.exit(0)

    if sys.argv[1] in ("--dependencies", "-d") and len(sys.argv) > 2:
        dep_pkg = os.path.basename(sys.argv[2])
        build_files = get_build_dependent_files(FOLDERS, dep_pkg)
        print(f"Bumping {len(build_files)} dependent package(s)\n")
        for f in build_files:
            bump_revision(f)
        sys.exit(0)

    # Default: bump specific packages
    packages = [os.path.basename(p.rstrip("/")) for p in sys.argv[1:]]
    print(f"Bumping {len(packages)} package(s)\n")
    for pkg in packages:
        build_file = locate_dir(pkg)
        bump_revision(build_file)
    sys.exit(0)


if __name__ == "__main__":
    parse_args()