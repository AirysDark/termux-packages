#!/usr/bin/env bash
# check-auto-update-linux.sh - Check if a package can be auto-updated on Linux-native packages-linux
# Converts Termux update logic to Linux-native
# MIT License
# Copyright (c) 2022 Aditya Alok <alok@termux.org>

set -euo pipefail

TERMUX_SCRIPTDIR="$(realpath "$(dirname "$0")/../..")"

# Colors
_RESET_COLOR="\033[0m"
_BLUE="\033[1;34m"
_GREEN="\033[0;32m"
_RED="\033[0;31m"
_YELLOW="\033[0;33m"
_TEAL="\033[0;36m"

SILENT=false
ENABLE=""

usage() {
    echo
    echo -e "${_BLUE}Usage:${_RESET_COLOR} $(basename "$0") [-h|--help] [-s|--silent] [--enable] PACKAGE_DIR"
    echo
    echo -e "${_TEAL}Check if Linux-native packages can be auto-updated and optionally enable it."
    echo
    echo -e "${_BLUE}Options:"
    echo -e "${_GREEN}-h --help${_TEAL} Show this help message."
    echo -e "${_GREEN}--enable${_TEAL} Enable auto-update for package (writes TERMUX_PKG_AUTO_UPDATE=true to build.sh)."
    echo -e "${_GREEN}-s --silent${_TEAL} Do not print anything to stdout."
    echo
    echo -e "${_BLUE}Example:${_RESET_COLOR} $(basename "$0") packages-linux/xorg-server"
    echo
}

color_print() {
    [[ "${SILENT}" == "true" ]] && return
    echo -e "$1${_RESET_COLOR}"
}

warn() {
    color_print "${_BLUE}[${_YELLOW}*${_BLUE}]${_YELLOW} $*" >&2
}

error() {
    local exit_cmd="return"
    [[ "$1" == "--exit" ]] && exit_cmd="exit" && shift
    color_print "${_BLUE}[${_RED}!${_BLUE}]${_RED} $*" >&2
    $exit_cmd 1
}

info() {
    color_print "${_BLUE}[${_GREEN}+${_BLUE}]${_TEAL} $*"
}

write_to_first_empty_line() {
    local file="$1"
    local line="$2"
    local first_empty_line
    first_empty_line=$(sed -n '/^$/=' "$file" | head -n1)
    if [[ -n "$first_empty_line" ]]; then
        sed -i "${first_empty_line}i$line" "$file"
    else
        echo "$line" >> "$file"
    fi
}

test_pkg() {
    local pkg_dir="$1"
    local pkg_name
    pkg_name="$(basename "$pkg_dir")"

    if [[ ! -f "${pkg_dir}/build.sh" ]]; then
        error --exit "Package '$pkg_name' does not exist."
    fi

    # Extract TERMUX_PKG_SRCURL and TERMUX_PKG_AUTO_UPDATE from build.sh
    local src_url auto_update
    eval "$(
        set +eu
        . "${pkg_dir}/build.sh" >/dev/null
        echo "src_url=\"${TERMUX_PKG_SRCURL}\";"
        echo "auto_update=\"${TERMUX_PKG_AUTO_UPDATE:-}\";"
    )"

    color_print "${_BLUE}==>${_YELLOW} $pkg_name"

    if [[ -n "$auto_update" ]]; then
        warn "Auto-update already set to '${auto_update}' in build.sh."
        return 0
    elif [[ -z "$src_url" ]]; then
        error "Could not find TERMUX_PKG_SRCURL."
    fi

    # Use Linux-native check for update
    local installed_version new_version
    installed_version="$(dpkg-query -W -f='${Version}' "$pkg_name" 2>/dev/null || echo "none")"
    new_version="$TERMUX_PKG_VERSION"

    if [[ "$installed_version" == "none" ]]; then
        info "Package '$pkg_name' not installed. Update needed."
        can_be_updated=true
    else
        if apt-compare-versions "$installed_version" lt "$new_version"; then
            info "Package '$pkg_name' can be updated: $installed_version → $new_version"
            can_be_updated=true
        else
            warn "Package '$pkg_name' is up-to-date ($installed_version)."
            can_be_updated=false
        fi
    fi

    # Enable auto-update if requested
    if [[ "$can_be_updated" == true && "$ENABLE" == "--enable" ]]; then
        info "Enabling auto-update for $pkg_name..."
        write_to_first_empty_line "$pkg_dir/build.sh" "TERMUX_PKG_AUTO_UPDATE=true"
        info "Auto-update enabled."
    fi
}

# Argument parsing
if [[ $# -lt 1 ]] || [[ $# -gt 3 ]]; then
    error --exit "Invalid number of arguments. See --help for usage."
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        --enable)
            ENABLE="$1"
            ;;
        -s|--silent)
            SILENT=true
            ;;
        -h|--help)
            usage
            ;;
        *)
            test_pkg "$1"
            [[ "$SILENT" == "true" ]] || echo
            ;;
    esac
    shift
done