#!/usr/bin/env bash
##
## update-packages-linux.sh - Auto-update Termux packages on Linux
##

set -euo pipefail

# ----------------------------
# Configuration (environment)
# ----------------------------
: "${BUILD_PACKAGES:=false}"
: "${CREATE_ISSUE:=false}"
: "${GIT_COMMIT_PACKAGES:=false}"
: "${GIT_PUSH_PACKAGES:=false}"
: "${TERMUX_ARCH:=aarch64}"

export TERMUX_PKG_AUTO_UPDATE=false
export TERMUX_SCRIPTDIR
TERMUX_SCRIPTDIR=$(realpath "$(dirname "$0")/../..")
export TERMUX_PACKAGES_DIRECTORIES
TERMUX_PACKAGES_DIRECTORIES=$(jq --raw-output 'del(.pkg_format) | keys | .[]' "$TERMUX_SCRIPTDIR/repo.json")

# ----------------------------
# Load required scripts
# ----------------------------
. "$TERMUX_SCRIPTDIR/scripts/properties.sh"
. "$TERMUX_SCRIPTDIR/scripts/build/termux_error_exit.sh"
. "$TERMUX_SCRIPTDIR/scripts/updates/utils/termux_pkg_upgrade_version.sh"
. "$TERMUX_SCRIPTDIR/scripts/updates/utils/termux_pkg_is_update_needed.sh"
. "$TERMUX_SCRIPTDIR/scripts/updates/api/termux_github_api_get_tag.sh"
. "$TERMUX_SCRIPTDIR/scripts/updates/api/termux_gitlab_api_get_tag.sh"
. "$TERMUX_SCRIPTDIR/scripts/updates/api/termux_repology_api_get_latest_version.sh"
. "$TERMUX_SCRIPTDIR/scripts/updates/internal/termux_github_auto_update.sh"
. "$TERMUX_SCRIPTDIR/scripts/updates/internal/termux_gitlab_auto_update.sh"
. "$TERMUX_SCRIPTDIR/scripts/updates/internal/termux_repology_auto_update.sh"
. "$TERMUX_SCRIPTDIR/scripts/updates/internal/termux_github_graphql.sh"
. "$TERMUX_SCRIPTDIR/scripts/updates/termux_pkg_auto_update.sh"

# ----------------------------
# Helpers
# ----------------------------
quiet() { "$@" &>/dev/null; return $?; }

_update_package() {
	local pkg_dir="$1"
	export TERMUX_PKG_NAME
	TERMUX_PKG_NAME="$(basename "$pkg_dir")"
	export TERMUX_PKG_BUILDER_DIR
	TERMUX_PKG_BUILDER_DIR="$(realpath "$pkg_dir")"

	set +eu
	if [ -f "$TERMUX_PKG_BUILDER_DIR/build.sh" ]; then
		. "$TERMUX_PKG_BUILDER_DIR/build.sh" 2>/dev/null
	fi
	set -eu

	echo
	echo "INFO: Updating ${TERMUX_PKG_NAME} [Current version: ${TERMUX_PKG_VERSION:-unknown}]"
	exec {IPC_FIFO_FD}<>"$IPC_FIFO"
	termux_pkg_auto_update 3>&"${IPC_FIFO_FD}"
	exec {IPC_FIFO_FD}>&-
}

# ----------------------------
# Fetch tags and check updates
# ----------------------------
declare -A _LATEST_TAGS=()
declare -A _FAILED_UPDATES=()
declare -A _ALREADY_SEEN=()

_fetch_and_cache_tags() {
	local pkg_dirs=("$@")
	for pkg_dir in "${pkg_dirs[@]}"; do
		# Skip packages that already call termux_pkg_auto_update in build.sh
		if [ -f "$pkg_dir/build.sh" ] && grep -q 'termux_pkg_auto_update' "$pkg_dir/build.sh"; then
			continue
		fi
		BUILD_PACKAGES=false quiet _should_update "$pkg_dir" || continue
	done
}

_run_update() {
	local pkg_dir="$1"
	local pkg_name="${pkg_dir##*/}"
	export TERMUX_PKG_NAME="$pkg_name"

	local _CURRENT_VERSION _NEWEST_VERSION output
	_CURRENT_VERSION="$(set +eu; [ -f "$pkg_dir/build.sh" ] && . "$pkg_dir/build.sh"; echo "${TERMUX_PKG_VERSION#*:}")"
	read -rt0.001 _ < "$IPC_FIFO"

	if output="$(set -euo pipefail; exec > >(tee /dev/fd/2) 2>&1; _update_package "$pkg_dir")"; then
		read -rt0.001 _NEWEST_VERSION < "$IPC_FIFO"
		: "${_NEWEST_VERSION:=${_CURRENT_VERSION}}"
		if termux_pkg_is_update_needed "$_CURRENT_VERSION" "$_NEWEST_VERSION"; then
			_ALREADY_SEEN["$pkg_name"]="$pkg_name $_CURRENT_VERSION => $_NEWEST_VERSION"
		else
			_ALREADY_SEEN["$pkg_name"]=""
		fi
	else
		_FAILED_UPDATES["$pkg_name"]="$output"
	fi
}

# ----------------------------
# Main update loop
# ----------------------------
_start_time="$(date +%10s%3N)"
rm -f "${TMPDIR:-/tmp}/termux_ipc_"*.fifo &>/dev/null
export IPC_FIFO="${TMPDIR:-/tmp}/termux_ipc_$$.fifo"
mkfifo "$IPC_FIFO"
exec {IPC_FIFO_FD}<>"$IPC_FIFO"

# Collect only root-packages if specified
declare -a PACKAGE_DIRS_LIST=()
for pkg in "$@"; do
	if [[ ! -d "$pkg" ]]; then
		for channel in $TERMUX_PACKAGES_DIRECTORIES; do
			if [[ "$channel" == "root-packages" ]] && [[ -d "$channel/$pkg" ]]; then
				PACKAGE_DIRS_LIST+=("$channel/$pkg")
				break
			fi
		done
	else
		# if directory passed directly, verify it's root-packages
		if [[ "$(basename "$(dirname "$pkg")")" == "root-packages" ]]; then
			PACKAGE_DIRS_LIST+=("$pkg")
		fi
	fi
done

_fetch_and_cache_tags "${PACKAGE_DIRS_LIST[@]}"

for pkg_dir in "${PACKAGE_DIRS_LIST[@]}"; do
	_should_update "$pkg_dir" || continue
	_run_update "$pkg_dir"
done

exec {IPC_FIFO_FD}<&-
rm -f "$IPC_FIFO"

# ----------------------------
# Summary
# ----------------------------
echo "SUMMARY: Updated packages:"
printf '%s\n' "${_ALREADY_SEEN[@]}" | grep -ve '^$' | sort

if (( ${#_FAILED_UPDATES[@]} > 0 )); then
	echo "Failed updates:"
	for pkg_name in "${!_FAILED_UPDATES[@]}"; do
		echo "$pkg_name"
	done
	exit 1
fi
