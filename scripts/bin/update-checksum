#!/usr/bin/env bash
##
## update-checksum-linux.sh - Update TERMUX_PKG_SHA256 in packages-linux
##

set -euo pipefail

if (( $# == 0 )); then
    echo "Usage: update-checksum-linux.sh [package dir] ..."
    echo
    echo "Update TERMUX_PKG_SHA256 of package(s) and optionally commit changes."
    exit 1
fi

REPO_ROOT=$(realpath "$(dirname "$0")/../../")
IS_GIT_REPO=false
git status >/dev/null 2>&1 && IS_GIT_REPO=true

# shellcheck source=scripts/properties.sh
source "$REPO_ROOT/scripts/properties.sh"

for package_dir in "$@"; do
    buildsh_path=""
    repo=""
    package_name="$(basename "$package_dir")"

    # Direct path to build.sh
    if [[ -d "$package_dir" && -f "$package_dir/build.sh" ]]; then
        buildsh_path="$package_dir/build.sh"
        repo="${package_dir%/*}"
    else
        # Search repo.json channels
        for channel in $(jq --raw-output 'del(.pkg_format) | keys | .[]' "$REPO_ROOT/repo.json"); do
            if [[ -d "$channel/$package_dir" && -f "$channel/$package_dir/build.sh" ]]; then
                buildsh_path="$channel/$package_dir/build.sh"
                repo="$channel"
                package_name="$package_dir"
                break
            fi
        done
    fi

    if [[ ! -f "$buildsh_path" ]]; then
        echo "Skipping $package_name: no build.sh found."
        continue
    fi

    # Calculate new SHA256
    mapfile -t new_checksums < <(
        source "$buildsh_path" 2>/dev/null
        for url in "${TERMUX_PKG_SRCURL[@]}"; do
            echo "Downloading $url..." >&2
            dl_tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/termux.src.XXXXXX")
            if curl -fsSL -o "$dl_tmpdir/source-bundle" "$url"; then
                sha256sum "$dl_tmpdir/source-bundle" | awk '{print $1}'
            fi
            rm -rf "$dl_tmpdir"
        done
    )

    if (( ${#new_checksums[@]} == 0 )); then
        echo "$package_name: failed to compute new checksum"
        continue
    fi

    # Update TERMUX_PKG_SHA256 in build.sh
    if (( ${#new_checksums[@]} > 1 )); then
        checksum="(\n$(printf '\t%s\n' "${new_checksums[@]}"))"
        sed -zi "s/\(TERMUX_PKG_SHA256=\)([^)]*)/\1${checksum}/g" "$buildsh_path"
    else
        sed -i "s/\(TERMUX_PKG_SHA256=\).*/\1${new_checksums[0]}/" "$buildsh_path"
    fi

    # Remove any existing TERMUX_PKG_REVISION
    sed -i "/TERMUX_PKG_REVISION=/d" "$buildsh_path"

    # Commit changes if in git repository
    if [[ "$IS_GIT_REPO" == "true" ]]; then
        echo
        echo "Diff for $package_name:"
        git --no-pager diff "$buildsh_path"
        read -r -p "Commit changes? (y/N) " choice
        if [[ "$choice" =~ ^[Yy]$ ]]; then
            git add "$buildsh_path"
            source "$buildsh_path" 2>/dev/null
            git commit -m "bump(${repo}/${package_name}): ${TERMUX_PKG_VERSION[0]}"
        else
            echo "Changes not committed."
        fi
        echo
    fi

    echo "$package_name: checksum updated successfully."
done